# Paradiso backend environment variables.
#
# Copy this file to backend/.env for local development:
#   cp backend/.env.example backend/.env
#
# Do NOT commit backend/.env. The repository .gitignore already excludes it.
# In Railway, configure these as Project Variables (do not check them into git).

# --- LLM providers (at least one is required for /api/ask) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Optional integrations (declared for forward-compatibility) ---
# These are read by future feature work (RAG, public-data caching, DB).
# The current backend does not require them to start.
LAW_API_KEY=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Service config ---
# Comma-separated list of allowed origins. Use "*" for development only.
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO

# Public-facing site URL (used as HTTP-Referer for OpenRouter calls and
# in disclaimers). Set to your deployed Paradiso frontend origin.
SITE_URL=

# Absolute path to visa_data.json. Useful when deploying with
# Root Directory = backend (the repo-root visa_data.json is then not
# part of the build context). Leave unset for local dev.
VISA_DATA_PATH=
